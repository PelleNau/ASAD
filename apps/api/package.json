{
  "name": "@asad/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/apps/api/src/index.js",
  "types": "./dist/apps/api/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/apps/api/src/index.d.ts",
      "default": "./dist/apps/api/src/index.js"
    },
    "./server": {
      "types": "./dist/apps/api/src/server.d.ts",
      "default": "./dist/apps/api/src/server.js"
    },
    "./fixtures": {
      "types": "./dist/apps/api/src/fixtures.d.ts",
      "default": "./dist/apps/api/src/fixtures.js"
    }
  },
  "scripts": {
    "start": "node dist/apps/api/src/server.js",
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@asad/assets": "workspace:*",
    "@asad/prompts": "workspace:*",
    "@asad/renderer": "workspace:*",
    "@asad/schemas": "workspace:*",
    "@asad/worker": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.2"
  }
}
