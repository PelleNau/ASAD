{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@asad/api": ["apps/api/src/index.ts"],
      "@asad/api/fixtures": ["apps/api/src/fixtures.ts"],
      "@asad/prompts": ["packages/prompts/src/index.ts"],
      "@asad/renderer": ["packages/renderer/src/index.ts"],
      "@asad/schemas": ["packages/schemas/src/index.ts"],
      "@asad/worker": ["apps/worker/src/index.ts"]
    },
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmitOnError": true
  }
}
